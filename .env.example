# In local dev you don't need this file — Vite's dev server proxy
# (vite.config.js) forwards /api to http://localhost:4000 automatically.
#
# In Netlify (production), set this as an Environment Variable in the
# Netlify dashboard (Site settings > Environment variables), pointing at
# your Render backend URL:
VITE_API_BASE_URL=https://your-backend-name.onrender.com/api
